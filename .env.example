# Copy to .env (never commit .env).

JWT_SECRET=

# Google Gemini (primary for test-case generation, form analysis, etc.). Create a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# Optional model id (default in app: gemini-2.5-flash). Use e.g. gemini-2.0-flash if quota or tier issues.
# GEMINI_MODEL=gemini-2.5-flash

# Groq (fallback when Gemini errors or rate-limits). https://console.groq.com
GROQ_API_KEY=
# Optional Groq models (defaults are set in ai.js).
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# API port (default 3000). Many hosts set PORT automatically — leave unset there if required.
PORT=3000

# Production: set NODE_ENV=production (trust proxy for HTTPS behind a load balancer).
# NODE_ENV=production

# Optional: SQLite path. If unset: local dev uses qahelper.db next to server.js; in production, if folder /data exists (e.g. Render disk mounted there), DB is /data/qahelper.db so data survives redeploys.
# DATABASE_PATH=/data/qahelper.db

# Free hosted SQLite (Turso) — use on Render free tier so data survives redeploys without a paid disk.
# Create a database at https://turso.tech — copy the libsql URL and auth token into Render environment variables.
# LIBSQL_URL=libsql://your-db-xxxxx.turso.io
# LIBSQL_AUTH_TOKEN=eyJ...
# (Aliases: TURSO_DATABASE_URL and TURSO_AUTH_TOKEN work the same.)

# If Turso fails with "unable to verify the first certificate" on a corporate network, for local dev only you may set:
# LIBSQL_RELAX_TLS=1
# That disables TLS verification for the entire Node process (including other HTTPS). Prefer NODE_EXTRA_CA_CERTS with your org root CA instead.

# Optional: SRD uploads folder. If unset: same rule — production uses /data/uploads when /data exists.
# UPLOADS_DIR=/data/uploads

# Optional: Notion integration for SRD import by URL.
# NOTION_API_KEY=secret_xxx

# Optional: lock browser CORS to your real site (comma-separated origins). If unset, all origins are allowed (fine for local dev).
# CORS_ORIGIN=https://your-app.onrender.com

# Playwright: leave unset on Render/Docker (headless). Set PLAYWRIGHT_HEADED=true only on your PC to see the browser window.
# PLAYWRIGHT_HEADED=true

# Local one-command prod: npm run prod  →  http://localhost:3000

# Docker:
#   docker build -t qa-helper .
#   docker run --rm -p 3000:3000 --env-file .env qa-helper
# Persist DB + uploads (example):
#   docker run --rm -p 3000:3000 --env-file .env -v qadata:/data -e DATABASE_PATH=/data/qahelper.db -e UPLOADS_DIR=/data/uploads qa-helper
