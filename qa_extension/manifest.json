{
  "manifest_version": 3,
  "name": "QA Helper",
  "version": "1.0",
  "description": "Tests Irembo forms automatically",
  "permissions": ["activeTab", "scripting", "tabs", "storage"],
  "host_permissions": [
    "http://localhost:3000/*",
    "http://localhost:5173/*",
    "https://citizen-portal.sandbox.iremboinc.com/*",
    "https://qa-helper-tool.onrender.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["config.js", "content.js"]
    }
  ]
}